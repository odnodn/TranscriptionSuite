# TranscriptionSuite Unified Server Dockerfile
#
# This image keeps application source and runtime bootstrap tooling.
# Python dependencies are installed at first container startup into /runtime/.venv.

FROM ubuntu:24.04 AS runtime

# PyTorch wheel-index variant (Issue #83):
#   cu129 (default) — modern GPUs, sm_70..sm_120 (Volta and newer)
#   cu126           — legacy-GPU image, sm_50..sm_90 (restores Pascal/Maxwell, e.g. GTX 1070)
#   cu130           — Blackwell GPUs, sm_121 (DGX Spark GB10, ARM64)
#   ngc             — NGC base image variant (see Dockerfile.dgx-spark)
# Selected at build time via `--build-arg PYTORCH_VARIANT=cu126` and consumed by
# bootstrap_runtime.py to switch the `uv sync` index. Default = cu129 keeps existing
# behaviour byte-identical for unchanged builds.
ARG PYTORCH_VARIANT=cu129

# OCI standard labels for container metadata
LABEL org.opencontainers.image.title="TranscriptionSuite Server"
LABEL org.opencontainers.image.description="Self contained server for TranscriptionSuite (PyTorch variant: ${PYTORCH_VARIANT})"
LABEL org.opencontainers.image.authors="homelab-00"
LABEL org.opencontainers.image.vendor="homelab-00"
LABEL org.opencontainers.image.source="https://github.com/homelab-00/TranscriptionSuite"
LABEL org.opencontainers.image.url="https://github.com/homelab-00/TranscriptionSuite"
LABEL org.opencontainers.image.documentation="https://github.com/homelab-00/TranscriptionSuite/blob/main/README.md"
LABEL org.opencontainers.image.licenses="GPL-3.0-or-later"

# Global environment
ENV DEBIAN_FRONTEND="noninteractive"
ENV PYTHONUNBUFFERED="1"
ENV PYTHONDONTWRITEBYTECODE="1"
ENV UV_PYTHON="3.13"
# Propagate the build-time PyTorch variant into runtime so bootstrap_runtime.py
# can branch its `uv sync` between the cu129 (default) and cu126 (legacy) index.
ENV PYTORCH_VARIANT="${PYTORCH_VARIANT}"
ENV BOOTSTRAP_RUNTIME_DIR="/runtime"
ENV BOOTSTRAP_CACHE_DIR="/runtime/cache"
ENV BOOTSTRAP_STATUS_FILE="/runtime/bootstrap-status.json"
ENV BOOTSTRAP_TIMEOUT_SECONDS="1800"
ENV BOOTSTRAP_REQUIRE_HF_TOKEN="false"
ENV BOOTSTRAP_LOG_CHANGES="true"
ENV UV_CACHE_DIR="/runtime/cache"
ENV HF_HOME="/models"
ENV TORCH_HOME="/models/torch-cache"
# Suppress the torchcodec/pyannote UserWarning at the interpreter level so it
# is silenced even in background threads that import pyannote.audio before any
# Python-level warnings.filterwarnings() call runs.
ENV PYTHONWARNINGS="ignore::UserWarning:pyannote.audio.core.io"

# Install runtime + bootstrap build prerequisites.
# Some Python packages still need local compilation on first bootstrap.
# Acquire::Retries + per-protocol Timeout make apt resilient to transient
# Launchpad/PPA CDN failures (e.g. handshake errors against deadsnakes).
RUN printf 'Acquire::Retries "5";\nAcquire::http::Timeout "30";\nAcquire::https::Timeout "30";\n' \
        > /etc/apt/apt.conf.d/80-retries \
    && apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    build-essential \
    python3.13 \
    python3.13-venv \
    python3.13-dev \
    ffmpeg \
    libsndfile1 \
    libportaudio2 \
    portaudio19-dev \
    curl \
    git \
    gosu \
    ca-certificates \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/0.10.8/install.sh | env UV_UNMANAGED_INSTALL="/usr/local/bin" sh

# Create non-root user for security with pinned UID/GID
RUN groupadd -g 10000 appuser && \
    useradd -u 10000 -g 10000 -m -s /bin/bash appuser

# Create app directory
WORKDIR /app

# Copy server application code and bootstrap tooling.
# Files are owned by appuser to avoid expensive recursive chown layers.
COPY --chown=appuser:appuser server/backend/ ./server/
COPY --chown=appuser:appuser server/docker/entrypoint.py ./docker/
COPY --chown=appuser:appuser server/docker/bootstrap_runtime.py ./docker/
COPY server/docker/docker-entrypoint.sh ./docker/
RUN chmod 700 ./docker/docker-entrypoint.sh

# Copy default configuration (users can override via mounted /user-config/config.yaml)
COPY server/config.yaml ./config.yaml

# Bake the resolved PYTORCH_VARIANT ARG into a file so bootstrap_runtime.py can
# cross-check the runtime env against the variant the image was actually built
# with (Issue #83 EC-5/EC-14). This is the source of truth for "which PyTorch
# wheels are installed" — runtime-env overrides are warned about and ignored.
RUN printf '%s\n' "${PYTORCH_VARIANT}" > /app/.pytorch_variant && \
    chown appuser:appuser /app/.pytorch_variant && \
    chmod 0644 /app/.pytorch_variant

# Create data directories with correct permissions
# /runtime is for first-run dependency bootstrap.
# /runtime/cache stores uv package cache (inside the runtime volume) for incremental updates.
RUN mkdir -p /data/database /data/audio /data/logs /data/tokens /data/certs /models /user-config /certs /runtime /runtime/cache && \
    chown -R appuser:appuser /data /models /user-config /runtime

# Environment variables
ENV DATA_DIR="/data"
ENV SERVER_HOST="0.0.0.0"
ENV SERVER_PORT="9786"
ENV LOG_LEVEL="INFO"
# Prioritize PyTorch bundled libraries from runtime venv.
# No `:$LD_LIBRARY_PATH` suffix: the ubuntu:24.04 base does not set this var
# and no earlier ENV declares it, so BuildKit would substitute an empty
# string — the resulting trailing colon would tell ld.so to also search
# the current working directory (`/app`), which is a latent foot-gun if
# anything ever drops a .so into the source tree.
ENV LD_LIBRARY_PATH="/runtime/.venv/lib/python3.13/site-packages/nvidia/cudnn/lib:/runtime/.venv/lib/python3.13/site-packages/torch/lib"
ENV PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True,garbage_collection_threshold:0.8"

# Expose port
EXPOSE 9786

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=600s --retries=3 \
    CMD curl -f http://localhost:${SERVER_PORT}/health || exit 1

# NOTE: We don't use USER directive here because the shell entrypoint needs
# to run as root initially to copy TLS certificates with proper permissions.
# The docker-entrypoint.sh script uses su-exec to drop to appuser before
# running the Python application.

# Shell entrypoint handles TLS cert permissions then drops to appuser
ENTRYPOINT ["./docker/docker-entrypoint.sh"]
CMD []
