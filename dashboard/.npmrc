# Enforce the Node engine pinned in package.json ("node": ">=22 <23") and .nvmrc
# (22.22.3). Without this, the engines field is advisory and running under an
# unsupported Node (e.g. nvm's default) fails later with a cryptic ESM crash:
# jsdom@28 -> html-encoding-sniffer@6 -> ESM-only @exodus/bytes, which Node <22.12
# cannot `require()` (ERR_REQUIRE_ESM) — every Vitest jsdom worker dies at boot.
# engine-strict makes `npm install`/`npm ci` fail fast with the version it needs.
# Run `nvm use` in this directory before npm commands.
engine-strict=true
