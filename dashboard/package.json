{
  "name": "transcriptionsuite",
  "private": true,
  "version": "1.3.6",
  "description": "Desktop dashboard for managing TranscriptionSuite server and transcription workflows.",
  "author": "homelab-00",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run ui:contract:check",
    "lighthouse": "npm run build && npx --yes @lhci/cli@0.13.x autorun --config=./lighthouserc.json",
    "test": "vitest run --passWithNoTests",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "package:linux": "npm run build:electron && electron-builder --linux AppImage --publish=never",
    "package:windows": "npm run build:electron && electron-builder --win nsis --publish=never",
    "package:mac": "npm run build:electron && electron-builder --mac dmg --publish=never",
    "ui:contract:extract": "node scripts/ui-contract/extract-facts.mjs",
    "ui:contract:build": "node scripts/ui-contract/build-contract.mjs",
    "ui:contract:validate": "node scripts/ui-contract/validate-contract.mjs",
    "ui:contract:check": "npm run ui:contract:validate && npm run ui:contract:test",
    "ui:contract:diff": "node scripts/ui-contract/diff-contract.mjs",
    "ui:contract:test": "node scripts/ui-contract/test-contract.mjs",
    "types:spec": "curl -s http://localhost:9786/openapi.json > src/api/openapi.json",
    "types:generate": "openapi-typescript src/api/openapi.json -o src/api/generated-types.ts",
    "audit:security": "npm audit --audit-level=moderate",
    "audit:licenses": "license-checker-rseidelsohn --production --summary"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@particle/dbus-next": "0.11.4",
    "@tanstack/react-query": "5.90.21",
    "chokidar": "^5.0.0",
    "electron-store": "11.0.2",
    "electron-updater": "^6.3.9",
    "lucide-react": "0.564.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "5.0.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "semver": "^7.7.4",
    "sonner": "2.0.7",
    "xxhash-wasm": "^1.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "5.1.4",
    "ajv": "8.18.0",
    "autoprefixer": "10.4.27",
    "electron": "^40.8.5",
    "electron-builder": "26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "3.0.1",
    "jsdom": "28.1.0",
    "license-checker-rseidelsohn": "4.4.2",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "4.1.8",
    "yaml": "^2.8.3"
  },
  "build": {
    "appId": "com.transcriptionsuite.dashboard",
    "productName": "TranscriptionSuite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist{,/**/*}",
      "dist-electron{,/**/*}"
    ],
    "extraResources": [
      {
        "from": "../docs/assets/logo.png",
        "to": "logo.png"
      },
      {
        "from": "../docs/assets/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "../docs/assets/tray-icon@1x.png",
        "to": "tray-icon@1x.png"
      },
      {
        "from": "../docs/assets/tray-icon@2x.png",
        "to": "tray-icon@2x.png"
      },
      {
        "from": "../server/docker/docker-compose.yml",
        "to": "docker/docker-compose.yml"
      },
      {
        "from": "../server/docker/docker-compose.linux-host.yml",
        "to": "docker/docker-compose.linux-host.yml"
      },
      {
        "from": "../server/docker/docker-compose.desktop-vm.yml",
        "to": "docker/docker-compose.desktop-vm.yml"
      },
      {
        "from": "../server/docker/docker-compose.gpu.yml",
        "to": "docker/docker-compose.gpu.yml"
      },
      {
        "from": "../server/docker/docker-compose.gpu-cdi.yml",
        "to": "docker/docker-compose.gpu-cdi.yml"
      },
      {
        "from": "../server/docker/podman-compose.gpu.yml",
        "to": "docker/podman-compose.gpu.yml"
      },
      {
        "from": "../server/docker/docker-compose.vulkan.yml",
        "to": "docker/docker-compose.vulkan.yml"
      },
      {
        "from": "../server/docker/docker-compose.vulkan-wsl2.yml",
        "to": "docker/docker-compose.vulkan-wsl2.yml"
      },
      {
        "from": "../server/config.yaml",
        "to": "config.yaml"
      },
      {
        "from": "../scripts/diagnose-gpu.sh",
        "to": "scripts/diagnose-gpu.sh"
      },
      {
        "from": "../scripts/README-gpu-diagnostic.md",
        "to": "scripts/README-gpu-diagnostic.md"
      }
    ],
    "afterPack": "./scripts/afterPack.cjs",
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "../docs/assets/logo.png"
    },
    "win": {
      "target": "nsis",
      "icon": "../docs/assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "../docs/assets/logo.icns",
      "hardenedRuntime": true,
      "entitlements": "../build/entitlements.mac.plist",
      "entitlementsInherit": "../build/entitlements.mac.plist",
      "extendInfo": {
        "NSAudioCaptureUsageDescription": "TranscriptionSuite needs access to system audio for transcription.",
        "NSAppleEventsUsageDescription": "TranscriptionSuite needs to paste transcribed text at your cursor position."
      }
    },
    "dmg": {
      "sign": false,
      "artifactName": "${productName}-${version}-${arch}-mac.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "homelab-00",
        "repo": "TranscriptionSuite"
      }
    ]
  },
  "overrides": {
    "js-yaml": "4.1.1",
    "minimatch": "10.2.4",
    "@develar/schema-utils": {
      "ajv": "6.14.0",
      "ajv-keywords": "3.5.2"
    }
  }
}
